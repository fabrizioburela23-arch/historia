generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums (como strings para flexibilidad)
// Role:            ADMIN | OPERATOR
// MachineStatus:   ACTIVE | MAINTENANCE | IDLE
// ProductType:     RAW | INTERMEDIATE | FINAL
// BatchMode:       SINGLE_FLOW | RECIPE
// ExecMode:        PARALLEL | SEQUENTIAL
// BatchStatus:     PENDING | IN_PROGRESS | PAUSED | COMPLETED | CANCELLED
// FlowRunStatus:   PENDING | IN_PROGRESS | PAUSED | COMPLETED | CANCELLED
// StepRunStatus:   PENDING | IN_PROGRESS | COMPLETED | SKIPPED

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String    // bcrypt hash (login)
  passwordPlain String    // plaintext (admin-visible)
  role          String    @default("OPERATOR")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  batchFlows    BatchFlow[]
  createdBatches Batch[]
}

model PlantLayout {
  id        String    @id @default(cuid())
  name      String
  imageUrl  String?
  machines  Machine[]
  createdAt DateTime  @default(now())
}

model Machine {
  id            String        @id @default(cuid())
  name          String
  description   String?
  code          String        @unique
  status        String        @default("ACTIVE")
  machineType   String?
  capacity      Float?
  capacityUnit  String?
  locationX     Float?
  locationY     Float?
  plantLayoutId String?
  plantLayout   PlantLayout?  @relation(fields: [plantLayoutId], references: [id])
  processFlows  ProcessFlow[]
  batchFlows    BatchFlow[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

// ===================== PRODUCTOS =====================

model Product {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  type        String   @default("RAW") // RAW | INTERMEDIATE | FINAL
  unit        String   // kg | g | L | ml | u
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  flowsAsInput        ProcessFlow[]    @relation("FlowInput")
  flowsAsOutput       ProcessFlow[]    @relation("FlowOutput")
  recipeMaterials     RecipeMaterial[]
  batchFlowsAsInput   BatchFlow[]      @relation("BatchFlowInput")
  batchFlowsAsOutput  BatchFlow[]      @relation("BatchFlowOutput")
}

// ===================== FLUJO DE PROCESO =====================

model ProcessFlow {
  id                String   @id @default(cuid())
  name              String
  description       String?
  machineId         String?
  machine           Machine? @relation(fields: [machineId], references: [id])

  inputProductId    String
  inputProduct      Product  @relation("FlowInput", fields: [inputProductId], references: [id])
  inputQty          Float
  inputUnit         String

  outputProductId   String
  outputProduct     Product  @relation("FlowOutput", fields: [outputProductId], references: [id])
  expectedOutputQty Float
  outputUnit        String

  targetTimeMinutes Int      @default(0)

  steps             ProcessStep[]
  recipeFlows       RecipeFlow[]
  batchFlows        BatchFlow[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ProcessStep {
  id                String              @id @default(cuid())
  flowId            String
  flow              ProcessFlow         @relation(fields: [flowId], references: [id], onDelete: Cascade)
  order             Int
  name              String
  description       String?
  targetTimeMinutes Int                 @default(0)
  checklistItems    FlowChecklistItem[]
  batchSteps        BatchStep[]
}

model FlowChecklistItem {
  id           String         @id @default(cuid())
  stepId       String
  step         ProcessStep    @relation(fields: [stepId], references: [id], onDelete: Cascade)
  label        String
  required     Boolean        @default(true)
  order        Int            @default(0)
  completions  BatchStepCheck[]
}

// ===================== RECETA =====================

model Recipe {
  id           String           @id @default(cuid())
  name         String
  description  String?
  version      String           @default("1.0")
  flows        RecipeFlow[]
  materials    RecipeMaterial[]
  batches      Batch[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model RecipeFlow {
  id        String      @id @default(cuid())
  recipeId  String
  recipe    Recipe      @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  flowId    String
  flow      ProcessFlow @relation(fields: [flowId], references: [id])
  order     Int         @default(0)

  @@unique([recipeId, flowId])
}

model RecipeMaterial {
  id        String  @id @default(cuid())
  recipeId  String
  recipe    Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Float
  unit      String

  @@unique([recipeId, productId])
}

// ===================== LOTE =====================

model Batch {
  id              String       @id @default(cuid())
  name            String
  mode            String       @default("SINGLE_FLOW") // SINGLE_FLOW | RECIPE
  executionMode   String       @default("SEQUENTIAL")  // PARALLEL | SEQUENTIAL
  status          String       @default("PENDING")
  priority        String       @default("NORMAL")
  notes           String?

  recipeId        String?
  recipe          Recipe?      @relation(fields: [recipeId], references: [id])

  supervisorName  String?
  createdById     String?
  createdBy       User?        @relation(fields: [createdById], references: [id])

  plannedStartAt  DateTime?
  plannedEndAt    DateTime?
  startedAt       DateTime?
  completedAt     DateTime?

  flows           BatchFlow[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

// Una ejecución de un flujo dentro de un lote
model BatchFlow {
  id                String      @id @default(cuid())
  batchId           String
  batch             Batch       @relation(fields: [batchId], references: [id], onDelete: Cascade)
  flowId            String
  flow              ProcessFlow @relation(fields: [flowId], references: [id])
  order             Int         @default(0)

  // Snapshot de input/output esperado (para no perderlo si cambia el flow)
  inputProductId    String
  inputProduct      Product     @relation("BatchFlowInput", fields: [inputProductId], references: [id])
  inputQtyPlanned   Float
  inputQtyActual    Float?
  inputUnit         String

  outputProductId   String
  outputProduct     Product     @relation("BatchFlowOutput", fields: [outputProductId], references: [id])
  outputQtyExpected Float
  outputQtyActual   Float?
  outputUnit        String

  machineId         String?
  machine           Machine?    @relation(fields: [machineId], references: [id])

  operatorId        String?
  operator          User?       @relation(fields: [operatorId], references: [id])

  status            String      @default("PENDING")
  startedAt         DateTime?
  completedAt       DateTime?

  // OEE inputs
  plannedTimeMin    Int         @default(0)   // suma de targetTimeMinutes de los pasos
  downtimeMin       Int         @default(0)   // tiempo perdido (operador lo registra)

  steps             BatchStep[]
}

model BatchStep {
  id                String          @id @default(cuid())
  batchFlowId       String
  batchFlow         BatchFlow       @relation(fields: [batchFlowId], references: [id], onDelete: Cascade)
  stepId            String
  step              ProcessStep     @relation(fields: [stepId], references: [id])
  order             Int             @default(0)
  status            String          @default("PENDING")
  startedAt         DateTime?
  completedAt       DateTime?
  actualTimeSeconds Int?
  observations      String?
  checks            BatchStepCheck[]
}

model BatchStepCheck {
  id               String             @id @default(cuid())
  batchStepId      String
  batchStep        BatchStep          @relation(fields: [batchStepId], references: [id], onDelete: Cascade)
  checklistItemId  String
  checklistItem    FlowChecklistItem  @relation(fields: [checklistItemId], references: [id])
  completed        Boolean            @default(false)
  completedAt      DateTime?

  @@unique([batchStepId, checklistItemId])
}
