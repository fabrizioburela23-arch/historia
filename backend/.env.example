# Base de datos PostgreSQL
# En Railway: copia el valor de DATABASE_URL que genera el add-on de Postgres
# Para desarrollo local puedes usar Neon (gratis): https://neon.tech
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Secreto para firmar JWT — cámbialo por algo largo y seguro en producción
JWT_SECRET="mes-industrial-secret-2024"

# Puerto del servidor
PORT=3001

# URL del frontend deployado (para CORS)
# Ej: FRONTEND_URL=https://mes-app.vercel.app
FRONTEND_URL=http://localhost:5173
